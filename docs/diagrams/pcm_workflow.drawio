<mxfile host="app.diagrams.net" modified="2026-02-28" type="device">
  <diagram name="PCM Workflow (v5.1 Grouped PCM)" id="pcm-workflow">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Predictive Coding (PCM) — v5.1 Grouped PCM Workflow&lt;/b&gt;" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- ==================== SCAN CONTEXT ==================== -->
        <mxCell id="scan_ctx" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4472C4;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="60" width="500" height="520" as="geometry"/>
        </mxCell>
        <mxCell id="scan_title" value="&lt;b&gt;Stage 1: Fast Scan&lt;/b&gt; (within scan recurrence)" style="text;html=1;align=left;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="65" width="350" height="25" as="geometry"/>
        </mxCell>

        <!-- Token t-1 -->
        <mxCell id="tok_prev" value="Token t−1 (previous step)" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="100" width="200" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="h_prev" value="H_{t-1} (grouped view of scan output)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, C, D_col] — free .view() from dense [BS, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="220" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="zhat_prev" value="z_hat_{t-1} = W_pcm · H_{t-1}&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, C, D_col] — PREDICTION of next token&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="80" y="185" width="250" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="pe1" style="endArrow=block;endFill=1;" edge="1" source="h_prev" target="zhat_prev" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Token t -->
        <mxCell id="tok_cur" value="Token t (current step)" style="text;html=1;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="245" width="200" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="x_t" value="X_t (token embedding, grouped view)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, C, D_col] — free .view() from dense [BS, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="275" width="250" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="z_t" value="z_t = W_enc · X_t&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, C, D_col] — ACTUAL encoding&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="200" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="pe2" style="endArrow=block;endFill=1;" edge="1" source="x_t" target="z_t" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Vector Surprise -->
        <mxCell id="surprise" value="&lt;b&gt;Vector Surprise&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;surprise_t = z_hat_{t-1} − z_t&lt;br&gt;[BS, C, D_col] — per-feature error&lt;br&gt;&lt;br&gt;Each dimension independently says:&lt;br&gt;&quot;I was wrong about THIS feature by THIS much&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="390" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="pe3" style="endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="zhat_prev" target="surprise" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pe4" style="endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="z_t" target="surprise" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Gain -->
        <mxCell id="gain" value="Gain Modulation (from surprise)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;gain = 1 + 0.1 · tanh(W_gain(surprise))&lt;br&gt;[BS, C, D_col] — bounded [0.9, 1.1]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="80" y="490" width="280" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="pe5" style="endArrow=block;endFill=1;" edge="1" source="surprise" target="gain" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== OUTPUTS ==================== -->
        <mxCell id="out_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;dashed=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="580" y="60" width="460" height="260" as="geometry"/>
        </mxCell>
        <mxCell id="out_title" value="&lt;b&gt;Surprise Outputs → Stage 2&lt;/b&gt;" style="text;html=1;align=left;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="590" y="65" width="250" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="out_pm" value="→ PM Bias Update&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pm_bias += lr_pm · surprise_mean&lt;br&gt;Column c's surprise only gates its D_col slice&lt;br&gt;Features well-predicted → no bias shift&lt;br&gt;Features surprising → bias drifts to compensate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="280" height="75" as="geometry"/>
        </mxCell>

        <mxCell id="out_em" value="→ EM Novelty Scoring&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;||surprise|| contributes to novelty score&lt;br&gt;novelty = w · ||surprise|| + (1−w) · recon_error&lt;br&gt;High novelty → decompose across primitives&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="600" y="195" width="280" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrows to outputs -->
        <mxCell id="pe6" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="surprise" target="out_pm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="pe7" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="surprise" target="out_em" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== LOSS ==================== -->
        <mxCell id="loss_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="580" y="350" width="460" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="loss_title" value="&lt;b&gt;PCM Optimization&lt;/b&gt;" style="text;html=1;align=left;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="590" y="355" width="150" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="pred_loss" value="&lt;b&gt;Prediction Loss (auxiliary)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;L_pred = MSE(z_hat_t, z_{t+1}.detach())&lt;br&gt;&lt;br&gt;Gradient flows to prediction network (W_pcm)&lt;br&gt;but NOT to encoding target (detached)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="610" y="395" width="280" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="downstream" value="&lt;b&gt;Downstream (implicit)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;surprise → PM bias shift, EM novelty gate&lt;br&gt;→ next segment reads → loss&lt;br&gt;PCM encoder learns what features matter&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="610" y="480" width="280" height="55" as="geometry"/>
        </mxCell>

        <!-- Key insight -->
        <mxCell id="insight" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;What Vector Surprise Means&lt;/b&gt;&lt;br&gt;&lt;br&gt;&quot;Based on causal context so far,&lt;br&gt;I predicted the next token's features.&lt;br&gt;The per-dimension error tells me&lt;br&gt;WHICH features I failed to anticipate&lt;br&gt;— those are worth writing to memory.&quot;&lt;br&gt;&lt;br&gt;v5.1: PCM remains grouped (per-feature-group)&lt;br&gt;while scan layers use dense nn.Linear.&lt;br&gt;Free .view() bridges dense ↔ grouped.&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="610" width="250" height="150" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
