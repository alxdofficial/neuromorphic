<mxfile host="app.diagrams.net" modified="2026-03-01" type="device">
  <diagram name="Episodic Memory — Trail-Based Primitives (v5.1)" id="em-workflow">
    <mxGraphModel dx="1200" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Episodic Memory — Trail-Based Primitive Composition (v5.1)&lt;/b&gt;" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="230" y="10" width="540" height="30" as="geometry"/>
        </mxCell>

        <!-- ==================== PRIMITIVE STATE ==================== -->
        <mxCell id="em_state" value="&lt;b&gt;EM Primitive Dictionary&lt;/b&gt; (state, not params — static within segment)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;em_K [BS, B, M, D] (unit-norm) — what triggers each primitive&lt;br&gt;em_V [BS, B, M, D] — what each primitive contributes&lt;br&gt;em_S [BS, B, M] (strengths, 0 = inactive)&lt;br&gt;em_age [BS, B, M]&lt;br&gt;&lt;br&gt;M primitives = atomic building blocks. Complex ideas emerge from composition.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="310" y="55" width="430" height="100" as="geometry"/>
        </mxCell>

        <!-- ==================== READ: TRAIL (Stage 2) ==================== -->
        <mxCell id="read_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="180" width="480" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="read_title" value="&lt;b&gt;EM Read — Trail-Based Pattern Completion (Stage 2)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Seed navigates primitive space via iterative refinement&lt;br&gt;Batched across all N positions — same primitives for entire segment&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="185" width="460" height="50" as="geometry"/>
        </mxCell>

        <!-- Seed -->
        <mxCell id="r_seed" value="[seed, w_cand] = W_seed_w · H (from Stage 1 scan)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, D] each — fused projection, chunk(2) split&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="245" width="230" height="35" as="geometry"/>
        </mxCell>

        <!-- Noise -->
        <mxCell id="r_noise" value="+ σ · ε (training only)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;σ learned per bank&lt;br&gt;ε ~ N(0, I) — exploration&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="340" y="245" width="160" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="re_noise" style="endArrow=block;endFill=1;dashed=1;strokeColor=#9673a6;" edge="1" source="r_noise" target="r_seed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Trail Step 1 -->
        <mxCell id="r_step1_label" value="&lt;b&gt;Trail Step 1&lt;/b&gt;" style="text;html=1;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="300" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="r_scores1" value="scores₁ = y @ em_K.T / τ&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, M] — ALL primitives scored (no top-k)&lt;br&gt;softmax → sparse activation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="325" width="250" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="r_delta1" value="δ₁ = attn₁ @ em_V&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, D] — weighted composition of primitives&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="385" width="250" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="r_gate1" value="gate₁ = σ(W_gate · [y; δ₁])&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;y = y + gate₁ · δ₁ — seed moves&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="435" width="220" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="re1" style="endArrow=block;endFill=1;" edge="1" source="r_seed" target="r_scores1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="re2" style="endArrow=block;endFill=1;" edge="1" source="r_scores1" target="r_delta1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="re3" style="endArrow=block;endFill=1;" edge="1" source="r_delta1" target="r_gate1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Trail Step 2 -->
        <mxCell id="r_step2_label" value="&lt;b&gt;Trail Step 2&lt;/b&gt; (from new position)" style="text;html=1;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="480" width="200" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="r_scores2" value="scores₂ = y @ em_K.T / τ&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Different primitives activate from new position!&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="505" width="260" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="r_gate2" value="y = y + gate₂ · (attn₂ @ em_V)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Second push — lands at destination&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="550" width="230" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="re4" style="endArrow=block;endFill=1;" edge="1" source="r_gate1" target="r_scores2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="re5" style="endArrow=block;endFill=1;" edge="1" source="r_scores2" target="r_gate2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Output -->
        <mxCell id="r_out" value="&lt;b&gt;y_em = y − seed&lt;/b&gt; (net memory contribution)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, D] — composition of activated primitives&lt;br&gt;Same primitives + different seed → different output (∞ combinations)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="350" y="520" width="350" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="re6" style="endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=2;" edge="1" source="r_gate2" target="r_out" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- em_state to scores arrows -->
        <mxCell id="re_state1" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="em_state" target="r_scores1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== NOVELTY (Stage 2) ==================== -->
        <mxCell id="nov_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4472C4;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="180" width="480" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="nov_title" value="&lt;b&gt;EM Novelty — Reconstruction Error (Stage 2)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Can existing primitives explain this input?&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="570" y="185" width="400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="n_cand" value="w_cand from scan&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, B, D] — write candidates&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="580" y="230" width="200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="n_recon" value="Reconstruction attempt&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;attn = softmax(norm(w_cand) @ em_K.T / τ)&lt;br&gt;recon = attn @ em_V&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="580" y="285" width="260" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="ne1" style="endArrow=block;endFill=1;" edge="1" source="n_cand" target="n_recon" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_error" value="recon_error = ||w_cand − recon||&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, B] — what existing primitives can't explain&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="580" y="350" width="280" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="ne2" style="endArrow=block;endFill=1;" edge="1" source="n_recon" target="n_error" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="n_surprise" value="||surprise|| from PCM&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, C] — prediction error magnitude&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="880" y="350" width="150" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="n_novelty" value="&lt;b&gt;novelty = w_nov · ||surprise|| + (1−w_nov) · recon_error&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, B] — blend of surprise and unexplained signal&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="580" y="415" width="380" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ne3" style="endArrow=block;endFill=1;" edge="1" source="n_error" target="n_novelty" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ne4" style="endArrow=block;endFill=1;" edge="1" source="n_surprise" target="n_novelty" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== FAST PATH: WRITE BUFFER (Stage 2) ==================== -->
        <mxCell id="buffer_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#d6b656;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="620" width="470" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="buffer_title" value="&lt;b&gt;EM Fast Path — Neuromodulated Causal Write Buffer (within segment)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Per-token neuromodulator gates write candidates before prefix-sum&lt;br&gt;Additive signal to Stage 3 (alongside trail read)&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="625" width="450" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="b_neuromod" value="g_em_t = MLP(novelty, usage)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, B] — per-token neuromodulator&lt;br&gt;Same MLP as slow path, applied per-token&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="70" y="685" width="220" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="b_delta" value="δ_em = (g_em_t · novelty).sum(B) · w_cand&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, D] — neuromodulated per-token write&lt;br&gt;g_em_t learns when writes help prediction&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="70" y="735" width="250" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="b_prefix" value="&lt;b&gt;cum_em = cumsum(δ_em, dim=seq)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, D] — causal accumulation&lt;br&gt;Position t sees neuromodulated writes from 0..t&lt;br&gt;Same-segment gradient flows to neuromod MLP&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="340" y="735" width="220" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="be0" style="endArrow=block;endFill=1;" edge="1" source="b_neuromod" target="b_delta" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="be1" style="endArrow=block;endFill=1;" edge="1" source="b_delta" target="b_prefix" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow from novelty to write buffer -->
        <mxCell id="nov_to_buffer" style="endArrow=block;endFill=1;strokeColor=#d6b656;strokeWidth=2;" edge="1" source="n_novelty" target="b_delta" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== SLOW PATH: SEGMENT-END COMMIT (Stage 2) ==================== -->
        <mxCell id="write_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="820" width="900" height="310" as="geometry"/>
        </mxCell>
        <mxCell id="write_title" value="&lt;b&gt;EM Slow Path — Segment-End Commit (structured decomposition)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Soft routing: each write signal spread across relevant primitives&lt;br&gt;Neuromodulated EMA → primitives updated for next segment&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="825" width="500" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="w_route" value="Soft routing to primitives&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;route = softmax(norm(w_cand) @ em_K.T / τ_w)&lt;br&gt;[BS, N, M] — which primitives absorb this signal&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="890" width="300" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="w_agg" value="Aggregate across N tokens&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;update_K = Σ_n(novelty · route · k_cand) → [BS, B, M, D]&lt;br&gt;update_V = Σ_n(novelty · route · v_cand) → [BS, B, M, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="955" width="340" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="we1" style="endArrow=block;endFill=1;" edge="1" source="w_route" target="w_agg" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="w_neuromod" value="&lt;b&gt;EMNeuromodulator&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;MLP → g_em (write gate)&lt;br&gt;Inputs: novelty_mean, usage (detached)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="470" y="890" width="220" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="w_ema" value="Neuromodulated EMA Update&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;α = g_em · route_aggregated  [BS, B, M]&lt;br&gt;em_K = (1−α) · em_K + α · norm(update_K)&lt;br&gt;em_V = (1−α) · em_V + α · update_V&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="80" y="1025" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="we2" style="endArrow=block;endFill=1;" edge="1" source="w_agg" target="w_ema" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="we3" style="endArrow=block;endFill=1;" edge="1" source="w_neuromod" target="w_ema" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="w_budget" value="Strength + Decay + Budget&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;em_S update, age, budget_enforce&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="440" y="1035" width="200" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="we4" style="endArrow=block;endFill=1;" edge="1" source="w_ema" target="w_budget" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="w_output" value="&lt;b&gt;Updated Primitives&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Available for next segment&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="1035" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="we5" style="endArrow=block;endFill=1;" edge="1" source="w_budget" target="w_output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow from novelty to slow path -->
        <mxCell id="nov_to_write" style="endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=2;" edge="1" source="n_novelty" target="w_route" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== TWO PATHS NOTE ==================== -->
        <mxCell id="paths_note" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Two Write Paths — Fast &amp; Slow&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Fast (within segment):&lt;/b&gt;&lt;br&gt;• g_em_t = MLP(novelty, usage) per-token&lt;br&gt;• δ_em = (g_em_t · novelty).sum(B) · w_cand&lt;br&gt;• cum_em = cumsum(δ_em) → Stage 3&lt;br&gt;• Neuromodulated, learned write selectivity&lt;br&gt;• Same-segment gradient to neuromod MLP&lt;br&gt;• Provides cross-column mixing (D-wide)&lt;br&gt;&lt;br&gt;&lt;b&gt;Slow (segment end):&lt;/b&gt;&lt;br&gt;• Structured routing into M primitives&lt;br&gt;• g_em = mean(g_em_t) — reuses per-token gates&lt;br&gt;• Neuromodulated EMA update&lt;br&gt;• Compressed, organized, persistent&lt;br&gt;• Cross-segment gradient (TBPTT)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="620" width="260" height="230" as="geometry"/>
        </mxCell>

        <!-- Key insight note -->
        <mxCell id="insight" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Why Trail-Based Composition&lt;/b&gt;&lt;br&gt;&lt;br&gt;Primitives are a fixed coordinate system.&lt;br&gt;The seed is a program that navigates it.&lt;br&gt;&lt;br&gt;Step 1: activate nearby primitives (e.g. &quot;animal&quot;, &quot;outdoor&quot;)&lt;br&gt;→ seed shifts toward dog+park space&lt;br&gt;Step 2: new primitives fire (e.g. &quot;running&quot;, &quot;fetch&quot;)&lt;br&gt;→ lands at &quot;dog running in park&quot;&lt;br&gt;&lt;br&gt;M primitives + continuous seeds = ∞ compositions&lt;br&gt;&lt;br&gt;Primitives are &lt;b&gt;state&lt;/b&gt; (evolve at inference).&lt;br&gt;Trail params are &lt;b&gt;weights&lt;/b&gt; (frozen after training).&lt;br&gt;This IS lifelong learning.&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="55" width="240" height="220" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
