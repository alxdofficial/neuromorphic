<mxfile host="app.diagrams.net" modified="2026-02-28" type="device">
  <diagram name="Overall Architecture" id="arch-overview">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;NeuromorphicLM v4 — Forward Pass (Single R-Loop)&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="270" y="10" width="420" height="30" as="geometry"/>
        </mxCell>

        <!-- Input -->
        <mxCell id="input" value="Input Tokens&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="60" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- Embedding -->
        <mxCell id="embed" value="Embedding [D_embed] + proj_up [D_embed→D] + Positional Encoding&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N, D_embed] → [BS, N, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="270" y="130" width="360" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="endArrow=block;endFill=1;" edge="1" source="input" target="embed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Fan-out -->
        <mxCell id="fanout" value="Fan-out: free view + expand&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N, D] → view [BS, N, C, D_col] → repeat B → [BS, N, G, D_col]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="270" y="200" width="360" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=block;endFill=1;" edge="1" source="embed" target="fanout" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- R-pass container -->
        <mxCell id="rloop" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="280" width="720" height="840" as="geometry"/>
        </mxCell>
        <mxCell id="rloop_label" value="&lt;b&gt;R Iterative Passes&lt;/b&gt; (r = 1..R)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;All modules weight-shared across passes (Universal Transformer style)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="285" width="450" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=block;endFill=1;" edge="1" source="fanout" target="rloop" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Column Group Forward -->
        <mxCell id="colgroup" value="&lt;b&gt;CorticalColumnGroup.forward&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;All G columns × all N tokens in parallel — one call per R pass&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="150" y="330" width="620" height="460" as="geometry"/>
        </mxCell>

        <!-- 1. PCM -->
        <mxCell id="pcm_surp" value="1. PCM Encode + Surprise + Gain&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;z = encode(x), surprise = ‖z − z_hat_prev‖&lt;br&gt;gain = 1 + 0.1·tanh(W_gain(delta))&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="365" width="280" height="45" as="geometry"/>
        </mxCell>

        <!-- 2. PM read -->
        <mxCell id="pm_read" value="2. PM Holographic Read&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;concat cols → [BS,N,B,D] → read → split back → residual&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="180" y="425" width="260" height="35" as="geometry"/>
        </mxCell>

        <!-- 3. EM read -->
        <mxCell id="em_read" value="3. EM Top-k Retrieval&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;concat cols → [BS,N,B,D] → read → split back → residual&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="470" y="425" width="260" height="35" as="geometry"/>
        </mxCell>

        <!-- 4. Lateral -->
        <mxCell id="lateral" value="4. LateralMixer [C,C]&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Local: cross-column mixing within each block&lt;br&gt;Zero-init residual&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="190" y="475" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- 4b. PositionAttention -->
        <mxCell id="pos_attn" value="4b. PositionAttention [N_C,N_C]&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Content-adaptive attention across N_C positions&lt;br&gt;Zero-init residual, O(N_C² × D_col) per group&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="475" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- 5. ffn_pre -->
        <mxCell id="ffn_pre" value="5. FFNStack (ffn_pre)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;L residual FFN layers&lt;br&gt;gain modulation on first layer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="190" y="530" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- 6. Cross-block -->
        <mxCell id="cross_block" value="6. CrossBlockMixer [B,B]&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Global: cross-block mixing for same column index&lt;br&gt;Zero-init residual&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="530" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- 7. ffn_post -->
        <mxCell id="ffn_post" value="7. FFNStack (ffn_post)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;L residual FFN layers&lt;br&gt;no gain modulation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="190" y="585" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- 8. PCM predict -->
        <mxCell id="pcm_pred" value="8. PCM Predict z_hat&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;z_hat = hyp_down(gelu(hyp_up(z)))&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="640" width="220" height="30" as="geometry"/>
        </mxCell>

        <!-- 9. W_post -->
        <mxCell id="pm_elig" value="9a. PM Eligibility Candidates&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;k_cand, v_cand, gate from W_post_fused&lt;br&gt;gate = (surprise / scale).clamp(0,1)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="180" y="685" width="230" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="em_nov" value="9b. EM Novelty Scoring&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;q_nov, v_cand, w_nov from W_post_fused&lt;br&gt;novelty = w·surprise + (1−w)·(1−max_sim)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="685" width="230" height="45" as="geometry"/>
        </mxCell>

        <!-- Commit and Write -->
        <mxCell id="commit" value="&lt;b&gt;PM Commit&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Route elig → slots&lt;br&gt;Neuromod → g, slot_logits, τ, ww&lt;br&gt;g *= elig_mag (pass-0 guard)&lt;br&gt;slot_logits −= ww · pm_a (weakness bias)&lt;br&gt;EMA update pm_K, pm_V, pm_a&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="150" y="820" width="230" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="write" value="&lt;b&gt;EM Write&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Select top-C candidates&lt;br&gt;Neuromod → g_em, τ, decay, ww&lt;br&gt;slot_scores += ww · weakness (learned bias)&lt;br&gt;EMA update em_K, em_V, em_S&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="820" width="230" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrows from column group to commit/write -->
        <mxCell id="e_elig" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="pm_elig" target="commit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_nov" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="em_nov" target="write" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PM/EM state feedback arrows -->
        <mxCell id="pm_fb" value="&lt;font style=&quot;font-size:9px&quot;&gt;updated PM state&lt;br&gt;for next pass&lt;/font&gt;" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;exitX=0;exitY=0.5;entryX=0;entryY=0.5;curved=1;" edge="1" source="commit" target="pm_read" parent="1">
          <mxGeometry x="-0.5" relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="120" y="860"/>
              <mxPoint x="120" y="443"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="em_fb" value="&lt;font style=&quot;font-size:9px&quot;&gt;updated EM state&lt;br&gt;for next pass&lt;/font&gt;" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=1;entryY=0.5;curved=1;" edge="1" source="write" target="em_read" parent="1">
          <mxGeometry x="-0.5" relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="800" y="860"/>
              <mxPoint x="800" y="443"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Damped mixing -->
        <mxCell id="damp" value="Damped Mixing: x = (1−λ)·x_prev + λ·x_out&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;λ = sigmoid(lambda_logit), learnable&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="290" y="930" width="320" height="40" as="geometry"/>
        </mxCell>

        <!-- z_hat feedback -->
        <mxCell id="zhat_fb" value="&lt;font style=&quot;font-size:9px;color:#9673a6;&quot;&gt;z_hat → z_hat_prev&lt;br&gt;for next pass&lt;/font&gt;" style="endArrow=block;endFill=1;dashed=1;strokeColor=#9673a6;exitX=0.5;exitY=0;entryX=0.5;entryY=1;curved=1;" edge="1" source="pcm_pred" target="pcm_surp" parent="1">
          <mxGeometry x="-0.3" relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="460" y="650"/>
              <mxPoint x="460" y="420"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Fan-in -->
        <mxCell id="fanin" value="Fan-in: mean across B blocks + D→D linear&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N, B, C, D_col] → reshape [BS, N, B, D] → mean(B) → fan_in → [BS, N, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="260" y="1160" width="380" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="endArrow=block;endFill=1;" edge="1" source="rloop" target="fanin" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- LM Head -->
        <mxCell id="lmhead" value="proj_down [D→D_embed] + LM Head&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N, D] → [BS, N, D_embed] → [BS, N, vocab]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="330" y="1230" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e7" style="endArrow=block;endFill=1;" edge="1" source="fanin" target="lmhead" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Output -->
        <mxCell id="output" value="Logits + Cross-Entropy Loss&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;+ α · PCM prediction loss&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="1300" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e8" style="endArrow=block;endFill=1;" edge="1" source="lmhead" target="output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Legend -->
        <mxCell id="leg_title" value="&lt;b&gt;Legend&lt;/b&gt;" style="text;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="60" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="Computation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="85" width="110" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="Memory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="115" width="110" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="Neuromodulator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="145" width="110" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="PCM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="175" width="110" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg5" value="I/O" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="205" width="110" height="25" as="geometry"/>
        </mxCell>

        <!-- Notes -->
        <mxCell id="state_note" value="&lt;font style=&quot;font-size:10px&quot;&gt;PM/EM state carries&lt;br&gt;across segments (TBPTT)&lt;br&gt;Detached at chunk boundary&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="860" y="280" width="150" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="ffn_note" value="&lt;font style=&quot;font-size:10px&quot;&gt;Total FFN layers per pass = 2L&lt;br&gt;(L = ffn_depth config)&lt;br&gt;ffn_pre: gain modulated&lt;br&gt;ffn_post: no gain&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="860" y="350" width="160" height="65" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
