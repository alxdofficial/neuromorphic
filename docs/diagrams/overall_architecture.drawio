<mxfile host="app.diagrams.net" modified="2026-02-27" type="device">
  <diagram name="Overall Architecture" id="arch-overview">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;NeuromorphicLM v4 — Forward Pass&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="310" y="10" width="330" height="30" as="geometry"/>
        </mxCell>

        <!-- Input -->
        <mxCell id="input" value="Input Tokens&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="60" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- Embedding -->
        <mxCell id="embed" value="Embedding + Positional Encoding&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="320" y="130" width="260" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="endArrow=block;endFill=1;" edge="1" source="input" target="embed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Fan-out -->
        <mxCell id="fanout" value="Fan-out Linear → reshape&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N, D] → [BS, N, B_blocks, C, D_col]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="290" y="200" width="320" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=block;endFill=1;" edge="1" source="embed" target="fanout" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- R-pass container -->
        <mxCell id="rloop" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="120" y="280" width="680" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="rloop_label" value="&lt;b&gt;R Iterative Passes&lt;/b&gt; (r = 1..R)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Column weights shared across passes&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="130" y="285" width="300" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=block;endFill=1;" edge="1" source="fanout" target="rloop" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Block container -->
        <mxCell id="blockloop" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;dashed=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="150" y="330" width="620" height="460" as="geometry"/>
        </mxCell>
        <mxCell id="blockloop_label" value="&lt;b&gt;For each Block b&lt;/b&gt; (b = 1..B_blocks), each with its own PM + EM" style="text;html=1;align=left;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="160" y="335" width="400" height="25" as="geometry"/>
        </mxCell>

        <!-- Column Group Forward -->
        <mxCell id="colgroup" value="&lt;b&gt;CorticalColumnGroup.forward&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;All C columns × all N tokens in parallel&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="200" y="370" width="520" height="250" as="geometry"/>
        </mxCell>

        <!-- Inside column group -->
        <mxCell id="pm_read" value="1. PM Holographic Read&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;W_pm_up(x) → read(q) → W_pm_down → residual&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="400" width="230" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="em_read" value="2. EM Top-k Retrieval&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;W_em_up(x) → read(q) → W_em_down → residual&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="470" y="400" width="230" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="pcm_surp" value="3. PCM Encode + Surprise&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;z = encode(x), surprise = ‖z − z_hat_prev‖&lt;br&gt;gain = 1 + 0.1·tanh(W_gain(delta))&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="455" width="240" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="ffn" value="4. FFN (gain-modulated)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;h = norm(x) * gain&lt;br&gt;x_out = x + ffn_down(gelu(ffn_up(h)))&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="455" width="220" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="pm_elig" value="5. PM Eligibility Candidates&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;k_cand = norm(W_k_pre(x_out))&lt;br&gt;v_cand = W_v_post(x_out)&lt;br&gt;gate = (surprise / scale).clamp(0,1)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="520" width="230" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="em_nov" value="6. EM Novelty Scoring&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;q_nov = norm(W_k_cand(x_out))&lt;br&gt;w_nov = σ(W_nov(x_out))&lt;br&gt;novelty = w·surprise + (1-w)·(1-max_sim)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="470" y="520" width="230" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="pcm_pred" value="7. PCM Predict z_hat&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;z_hat = hyp_down(gelu(hyp_up(z)))&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="305" y="585" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- Commit and Write -->
        <mxCell id="commit" value="&lt;b&gt;PM Commit&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Route elig → slots&lt;br&gt;Neuromod → g, slot_logits, τ&lt;br&gt;EMA update pm_K, pm_V, pm_a&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="640" width="200" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="write" value="&lt;b&gt;EM Write&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Select top-C candidates&lt;br&gt;Neuromod → g_em, τ, decay&lt;br&gt;EMA update em_K, em_V, em_S&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="640" width="200" height="65" as="geometry"/>
        </mxCell>

        <!-- Arrows from column group to commit/write -->
        <mxCell id="e_elig" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="pm_elig" target="commit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_nov" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="em_nov" target="write" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PM/EM state feedback arrows -->
        <mxCell id="pm_fb" value="&lt;font style=&quot;font-size:9px&quot;&gt;updated PM state&lt;br&gt;for next pass&lt;/font&gt;" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;exitX=0;exitY=0.5;entryX=0;entryY=0.5;curved=1;" edge="1" source="commit" target="pm_read" parent="1">
          <mxGeometry x="-0.5" relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="170" y="672"/>
              <mxPoint x="170" y="420"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="em_fb" value="&lt;font style=&quot;font-size:9px&quot;&gt;updated EM state&lt;br&gt;for next pass&lt;/font&gt;" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;exitX=1;exitY=0.5;entryX=1;entryY=0.5;curved=1;" edge="1" source="write" target="em_read" parent="1">
          <mxGeometry x="-0.5" relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="750" y="672"/>
              <mxPoint x="750" y="420"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Damped mixing -->
        <mxCell id="damp" value="Damped Mixing: x = (1−λ)·x_prev + λ·x_out&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;λ = sigmoid(lambda_logit), learnable&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="290" y="730" width="320" height="40" as="geometry"/>
        </mxCell>

        <!-- z_hat feedback -->
        <mxCell id="zhat_fb" value="&lt;font style=&quot;font-size:9px;color:#9673a6;&quot;&gt;z_hat → z_hat_prev&lt;br&gt;for next pass&lt;/font&gt;" style="endArrow=block;endFill=1;dashed=1;strokeColor=#9673a6;exitX=0.5;exitY=0;entryX=0.5;entryY=1;curved=1;" edge="1" source="pcm_pred" target="pcm_surp" parent="1">
          <mxGeometry x="-0.3" relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="460" y="590"/>
              <mxPoint x="460" y="505"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Fan-in -->
        <mxCell id="fanin" value="Fan-in Linear + LayerNorm&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N, B*C*D_col] → [BS, N, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="310" y="940" width="280" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e6" style="endArrow=block;endFill=1;" edge="1" source="rloop" target="fanin" parent="1">
