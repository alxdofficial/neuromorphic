<mxfile host="app.diagrams.net" modified="2026-02-28" type="device">
  <diagram name="Overall Architecture" id="arch-overview">
    <mxGraphModel dx="1400" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;NeuromorphicLM v5 — Scan-Memory-Scan Forward Pass&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="320" y="10" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- Input -->
        <mxCell id="input" value="Input Tokens&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="60" width="200" height="40" as="geometry"/>
        </mxCell>

        <!-- Embedding -->
        <mxCell id="embed" value="Embedding [D_embed] + proj_up [D_embed→D] + Positional Encoding&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N, D_embed] → [BS, N, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="330" y="130" width="440" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="endArrow=block;endFill=1;" edge="1" source="input" target="embed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Column slicing note -->
        <mxCell id="col_slice" value="Column Slicing (free view, no params)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Column c sees x[..., c·D_col : (c+1)·D_col]&lt;br&gt;[BS, N, D] → C views of [BS, N, D_col]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="330" y="200" width="440" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="endArrow=block;endFill=1;" edge="1" source="embed" target="col_slice" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== STAGE 1 ==================== -->
        <mxCell id="stage1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4472C4;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="280" width="900" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="stage1_label" value="&lt;b&gt;Stage 1: Fast Scan&lt;/b&gt; (Neocortical Stream)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Causal affine recurrence — parallelized via chunked parallel-scan&lt;br&gt;All C columns process every token, each seeing D_col features&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="285" width="500" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="endArrow=block;endFill=1;" edge="1" source="col_slice" target="stage1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Scan recurrence -->
        <mxCell id="scan1" value="Linear Recurrence (element-wise)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;h_t = a_t ⊙ h_{t-1} + b_t&lt;br&gt;Per column: h_c,t ∈ R^{D_col}&lt;br&gt;Columns independent — no lateral mixing&lt;br&gt;a_t, b_t = input-dependent projections&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="130" y="350" width="270" height="65" as="geometry"/>
        </mxCell>

        <!-- PCM encode + surprise -->
        <mxCell id="pcm_scan" value="PCM Encode + Vector Surprise&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;z = W_enc · X_t, z_hat = W_pcm · H_t&lt;br&gt;surprise_t = z_hat_{t-1} − z_t&lt;br&gt;[BS, N, C, D_col] — per-feature error&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="130" y="475" width="270" height="55" as="geometry"/>
        </mxCell>

        <!-- Scan outputs -->
        <mxCell id="scan_h" value="H (column states)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, C, D_col]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="450" y="350" width="170" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="scan_q" value="seed (EM trail starts)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;W_seed_w · H → chunk → [BS, N, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="450" y="400" width="200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="scan_w" value="w_cand (write candidates)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;W_seed_w · H → chunk → [BS, N, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="450" y="445" width="200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="scan_surp" value="surprise (vector)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, C, D_col] — per-feature&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="450" y="495" width="200" height="35" as="geometry"/>
        </mxCell>

        <!-- Arrows from scan to outputs -->
        <mxCell id="e_s1" style="endArrow=block;endFill=1;" edge="1" source="scan1" target="scan_h" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Memory state (right side of Stage 1) -->
        <mxCell id="mem_state" value="&lt;b&gt;Memory State&lt;/b&gt; (from prev segment)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;PM: pm_bias [BS, B, D]&lt;br&gt;EM: em_K, em_V, em_S [BS, B, M, D]&lt;br&gt;Static within segment&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="720" y="350" width="250" height="65" as="geometry"/>
        </mxCell>

        <!-- ==================== STAGE 2 ==================== -->
        <mxCell id="stage2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="600" width="900" height="310" as="geometry"/>
        </mxCell>
        <!-- Stage 2: write-before-read with causal prefix sums -->
        <mxCell id="stage2_label" value="&lt;b&gt;Stage 2: Memory Operations&lt;/b&gt; (Hippocampal Loop)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Write-before-read with causal write buffers (prefix sums) — batched across N&lt;br&gt;Column c addresses dims c·D_col:(c+1)·D_col of bank b&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="605" width="550" height="50" as="geometry"/>
        </mxCell>

        <!-- Write Deltas (per-token, parallel) -->
        <mxCell id="write_deltas" value="&lt;b&gt;Per-Token Write Deltas&lt;/b&gt; (parallel, from frozen state)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;δ_pm = lr_pm · surprise — [BS, N, D]&lt;br&gt;δ_em = novelty · w_cand — [BS, N, D]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="130" y="665" width="260" height="50" as="geometry"/>
        </mxCell>

        <!-- Prefix Sums -->
        <mxCell id="prefix_sums" value="&lt;b&gt;Causal Prefix Sums&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;cum_pm = cumsum(δ_pm, dim=seq) — [BS, N, D]&lt;br&gt;cum_em = cumsum(δ_em, dim=seq) — [BS, N, D]&lt;br&gt;Position t sees writes from tokens 0..t (inclusive, causal for NTP)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="420" y="665" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="e_dp" style="endArrow=block;endFill=1;" edge="1" source="write_deltas" target="prefix_sums" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PM Read (with causal bias) -->
        <mxCell id="pm_read" value="&lt;b&gt;PM Delta Modulation&lt;/b&gt; (causal)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;delta_pm = H ⊙ (pm_bias + cum_pm)&lt;br&gt;Frozen bias + within-segment updates&lt;br&gt;[BS, N, B, D] — baseline H added once in Stage 3&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="130" y="740" width="230" height="55" as="geometry"/>
        </mxCell>

        <!-- EM Read (from frozen) -->
        <mxCell id="em_read" value="&lt;b&gt;EM Trail Composition&lt;/b&gt; (from frozen)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;seed → trail (2 steps) through M primitives&lt;br&gt;softmax → compose → gate → move&lt;br&gt;y_em = final_pos − seed&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="390" y="740" width="230" height="55" as="geometry"/>
        </mxCell>

        <!-- Three signals to Stage 3 -->
        <mxCell id="mem_reads" value="Four signals → Stage 3: H + pm_delta + em_read + cum_em&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pm_read: long-term bias (frozen + causal buffer)&lt;br&gt;em_read: long-term compositional (trail from frozen primitives)&lt;br&gt;cum_em: within-segment new info (prefix-summed write candidates)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="130" y="820" width="400" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e_mr1" style="endArrow=block;endFill=1;" edge="1" source="pm_read" target="mem_reads" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_mr2" style="endArrow=block;endFill=1;" edge="1" source="em_read" target="mem_reads" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_mr3" style="endArrow=block;endFill=1;strokeColor=#d6b656;" edge="1" source="prefix_sums" target="mem_reads" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrows: prefix sums to PM read (causal bias) -->
        <mxCell id="e_ps_pm" style="endArrow=block;endFill=1;dashed=1;strokeColor=#d6b656;" edge="1" source="prefix_sums" target="pm_read" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Segment-End Commit -->
        <mxCell id="pm_commit" value="&lt;b&gt;PM Segment-End Commit&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pm_bias += Σ_n δ_pm (sum of all deltas)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="640" y="740" width="200" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="em_write" value="&lt;b&gt;EM Segment-End Commit&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Soft routing → neuromod → EMA&lt;br&gt;Structured decomposition into primitives&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="640" y="800" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- Memory state update -->
        <mxCell id="mem_update" value="&lt;font style=&quot;font-size:9px&quot;&gt;Updated PM/EM state&lt;br&gt;→ next segment&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="770" width="120" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_mu1" style="endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="pm_commit" target="mem_update" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_mu2" style="endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="em_write" target="mem_update" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Decay/age -->
        <mxCell id="decay_age" value="Decay + Age Tick&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pm_bias decay → 0, em.age_tick(N)&lt;br&gt;Once per segment (not per token)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="855" y="830" width="150" height="45" as="geometry"/>
        </mxCell>

        <!-- Arrows from Stage 1 outputs to Stage 2 -->
        <mxCell id="e_s2a" style="endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="scan_h" target="pm_read" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_s2b" style="endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="scan_q" target="em_read" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_s2c" style="endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="scan_w" target="em_write" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_s2d" style="endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="scan_surp" target="pm_commit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_s2e" style="endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="scan_surp" target="em_write" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow from memory state to reads -->
        <mxCell id="e_ms1" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="mem_state" target="pm_read" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_ms2" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="mem_state" target="em_read" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== STAGE 3 ==================== -->
        <mxCell id="stage3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4472C4;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="950" width="900" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="stage3_label" value="&lt;b&gt;Stage 3: Integration Scan&lt;/b&gt; (Context Fusion)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Second causal scan — integrates memory reads with column states&lt;br&gt;Parallelized via chunked parallel-scan&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="110" y="955" width="500" height="45" as="geometry"/>
        </mxCell>

        <!-- Integration scan -->
        <mxCell id="scan2" value="Integration Scan (element-wise)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;h'_t = a'_t ⊙ h'_{t-1} + b'_t&lt;br&gt;Input: H + pm_delta + em_read + cum_em (four signals, additive)&lt;br&gt;Columns independent&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="200" y="1015" width="300" height="50" as="geometry"/>
        </mxCell>

        <!-- Output projection -->
        <mxCell id="out_proj" value="Output: reshape → proj_down → LM Head&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, D] → [BS, N, D_embed] → [BS, N, vocab]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="580" y="1015" width="280" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="e_s3a" style="endArrow=block;endFill=1;" edge="1" source="scan2" target="out_proj" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrows into Stage 3 -->
        <mxCell id="e_s3b" style="endArrow=block;endFill=1;" edge="1" source="scan_h" target="scan2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e_s3c" style="endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="mem_reads" target="scan2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Output -->
        <mxCell id="output" value="NTP Loss: CE(logits_t, token_{t+1}) + α · PCM prediction loss" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="1200" width="400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e_out" style="endArrow=block;endFill=1;" edge="1" source="stage3" target="output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Memory carry arrow -->
        <mxCell id="mem_carry" value="&lt;font style=&quot;font-size:9px;color:#82b366;&quot;&gt;PM/EM state carries&lt;br&gt;to next segment (TBPTT)&lt;/font&gt;" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;curved=1;" edge="1" source="mem_update" target="mem_state" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1020" y="790"/>
              <mxPoint x="1020" y="383"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="leg_title" value="&lt;b&gt;Legend&lt;/b&gt;" style="text;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1080" y="60" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="Computation / Scan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="85" width="130" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="Memory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="115" width="130" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="Write Buffer / Commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="145" width="130" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="PCM / Surprise" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="175" width="130" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="leg5" value="I/O" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="205" width="130" height="25" as="geometry"/>
        </mxCell>

        <!-- Notes -->
        <mxCell id="note1" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Key Properties&lt;/b&gt;&lt;br&gt;• Causal within segment (scan)&lt;br&gt;• Causal across segments (memory)&lt;br&gt;• Causal write buffers (prefix sums)&lt;br&gt;• Two write paths: fast (same seg) + slow (commit)&lt;br&gt;• Write-before-read (cum_pm in gain)&lt;br&gt;• Three signals to Stage 3&lt;br&gt;• No R-loop — single cycle&lt;br&gt;• NTP training (not FITB)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="260" width="200" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="note2" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Column-Local Addressing&lt;/b&gt;&lt;br&gt;Column c of bank b addresses:&lt;br&gt;dims c·D_col : (c+1)·D_col&lt;br&gt;Pure dimension slice — no routing&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="410" width="180" height="80" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
