        <mxCell id="lmhead" value="LM Head (Linear)&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;[BS, N, D] → [BS, N, vocab]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="330" y="1010" width="240" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="e7" style="endArrow=block;endFill=1;" edge="1" source="fanin" target="lmhead" parent="1">
