<mxfile>
  <diagram name="Working Memory" id="working-memory">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===================== TITLE ===================== -->
        <mxCell id="2" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;&lt;b&gt;Working Memory (WM) — Gated Linear Attention&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="560" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="&lt;font color=&quot;#808080&quot; style=&quot;font-size: 11px;&quot;&gt;1 shared instance across the entire model. Provides short-context precision (copying, binding).&lt;br&gt;No post-training evolution — recurrent state with learned decay gates. Fallback: softmax ring buffer (wm_type=&amp;quot;softmax&amp;quot;).&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="52" width="700" height="35" as="geometry"/>
        </mxCell>

        <!-- ===================== CONFIG BOX ===================== -->
        <mxCell id="4" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Configuration&lt;/b&gt;&lt;br&gt;wm_type = &amp;quot;gla&amp;quot; (default) or &amp;quot;softmax&amp;quot;&lt;br&gt;D_wm = 128 (key/value dimension)&lt;br&gt;n_heads = 4 (attention heads)&lt;br&gt;head_dim = D_wm / n_heads = 32&lt;br&gt;gate_low_rank = 16 (gate bottleneck dim)&lt;br&gt;&lt;br&gt;&lt;b&gt;State (per stream):&lt;/b&gt;&lt;br&gt;gla_state: [BS, H, head_dim, head_dim] float32&lt;br&gt;&amp;nbsp;&amp;nbsp;— recurrent state matrix (1 per head)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="980" y="20" width="300" height="175" as="geometry"/>
        </mxCell>

        <!-- ===================== INPUT ===================== -->
        <mxCell id="10" value="&lt;b&gt;x&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot; color=&quot;#888&quot;&gt;[BS, D]&lt;br&gt;token embedding&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="120" width="140" height="55" as="geometry"/>
        </mxCell>

        <!-- ===================== Q/K/V/G PROJECTIONS ===================== -->
        <mxCell id="20" value="&lt;b&gt;W_q&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot; color=&quot;#555&quot;&gt;Linear(D, D_wm)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="230" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="&lt;b&gt;W_k&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot; color=&quot;#555&quot;&gt;Linear(D, D_wm)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="230" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="22" value="&lt;b&gt;W_v&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot; color=&quot;#555&quot;&gt;Linear(D, D_wm)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="230" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="22b" value="&lt;b&gt;W_g&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot; color=&quot;#555&quot;&gt;D → 16 → D_wm&lt;br&gt;(low-rank gate)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="230" width="120" height="45" as="geometry"/>
        </mxCell>

        <!-- Arrows from x to Q/K/V/G -->
        <mxCell id="23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" source="10" target="20" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="24" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" source="10" target="21" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="25" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" source="10" target="22" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="25b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" source="10" target="22b" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Labels -->
        <mxCell id="26" value="&lt;font color=&quot;#4a86c8&quot; style=&quot;font-size: 9px;&quot;&gt;q [BS, H, K]&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="65" y="280" width="90" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="27" value="&lt;font color=&quot;#4a86c8&quot; style=&quot;font-size: 9px;&quot;&gt;k [BS, H, K]&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="230" y="280" width="90" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="28" value="&lt;font color=&quot;#4a86c8&quot; style=&quot;font-size: 9px;&quot;&gt;v [BS, H, V]&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="390" y="280" width="90" height="15" as="geometry"/>
        </mxCell>
        <mxCell id="28b" value="&lt;font color=&quot;#9673a6&quot; style=&quot;font-size: 9px;&quot;&gt;g = logsigmoid(·)/16&lt;br&gt;[BS, H, K]&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="535" y="280" width="130" height="25" as="geometry"/>
        </mxCell>

        <!-- ===================== GLA RECURRENCE ===================== -->
        <mxCell id="30" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;verticalAlign=top;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="600" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;b&gt;GLA Recurrence (per token t)&lt;/b&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="70" y="335" width="260" height="20" as="geometry"/>
        </mxCell>

        <!-- Decay step -->
        <mxCell id="32" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;1. Decay&lt;/b&gt;&lt;br&gt;S = diag(exp(g_t)) × S&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;Forget old context (learned rate per dim)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="250" height="55" as="geometry"/>
        </mxCell>

        <!-- Write step -->
        <mxCell id="33" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;2. Write&lt;/b&gt;&lt;br&gt;S = S + k_t&lt;sup&gt;T&lt;/sup&gt; ⊗ v_t&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;Outer product adds new information&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="370" y="370" width="250" height="55" as="geometry"/>
        </mxCell>

        <!-- Read step -->
        <mxCell id="34" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;3. Read&lt;/b&gt;&lt;br&gt;o_t = q_t × S&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;Query against accumulated state&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="450" width="250" height="55" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="35" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" source="32" target="33" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="36" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" source="33" target="34" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- State matrix visual -->
        <mxCell id="37" value="&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;b&gt;State S&lt;/b&gt; [BS, H, K, V]&lt;br&gt;┌──────────────┐&lt;br&gt;│ head 0: 32×32│&lt;br&gt;│ head 1: 32×32│&lt;br&gt;│ head 2: 32×32│&lt;br&gt;│ head 3: 32×32│&lt;br&gt;└──────────────┘&lt;br&gt;&lt;font color=&quot;#888&quot;&gt;float32, per stream&lt;/font&gt;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;strokeColor=#6c8ebf;fillColor=#eef3ff;rounded=1;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="500" y="440" width="140" height="100" as="geometry"/>
        </mxCell>

        <!-- ===================== OUTPUT PROJECTION ===================== -->
        <mxCell id="60" value="&lt;b&gt;W_o&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot; color=&quot;#555&quot;&gt;Linear(D_wm, D)&lt;br&gt;Merge heads + output projection&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="590" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="61" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" source="34" target="60" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Output -->
        <mxCell id="62" value="&lt;b&gt;y_wm&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot; color=&quot;#888&quot;&gt;[BS, D]&lt;br&gt;Shared across all B blocks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="210" y="690" width="170" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="63" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fontSize=9;" edge="1" source="60" target="62" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===================== RESET BEHAVIOR ===================== -->
        <mxCell id="70" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Doc Boundary Reset (per stream):&lt;/b&gt;&lt;br&gt;• gla_state[stream] = 0 (zero the state matrix)&lt;br&gt;• Applied per-token in recurrence loop&lt;br&gt;• Mid-span resets handled: state zeroed before reset token&lt;br&gt;&lt;br&gt;&lt;b&gt;TBPTT Boundary:&lt;/b&gt;&lt;br&gt;• State carries over (detached at chunk boundaries)&lt;br&gt;• Gradients flow through recurrence within chunks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0ff;strokeColor=#9999cc;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="800" y="330" width="310" height="140" as="geometry"/>
        </mxCell>

        <!-- ===================== DATA FLOW SUMMARY ===================== -->
        <mxCell id="80" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Per-Token Data Flow (GLA):&lt;/b&gt;&lt;br&gt;1. Project: q = W_q(x), k = W_k(x), v = W_v(x)&lt;br&gt;2. Gate: g = logsigmoid(W_g(x)) / 16  — learned decay&lt;br&gt;3. Decay: S *= diag(exp(g))&lt;br&gt;4. Write: S += k&lt;sup&gt;T&lt;/sup&gt; ⊗ v  (outer product)&lt;br&gt;5. Read: o = q × S  → merge heads&lt;br&gt;6. Output: y_wm = dropout(W_o(o))&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="800" y="510" width="310" height="120" as="geometry"/>
        </mxCell>

        <!-- ===================== COMPARISON NOTE ===================== -->
        <mxCell id="90" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;vs Softmax Ring Buffer (wm_type=&amp;quot;softmax&amp;quot;):&lt;/b&gt;&lt;br&gt;• State: 4 tensors (wm_K, wm_V, wm_valid, wm_ptr) → 1 tensor (gla_state)&lt;br&gt;• Recency: ALiBi fixed slopes → learned decay gates&lt;br&gt;• Capacity: W=256 explicit slots → compressed H×K×V matrix&lt;br&gt;• Sacred properties preserved: fixed-size, non-plastic, resettable&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#cccccc;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="800" y="660" width="310" height="95" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
