<mxfile host="app.diagrams.net" modified="2026-02-27" type="device">
  <diagram name="Procedural Memory Workflow" id="pm-workflow">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Procedural Memory — Full Workflow&lt;/b&gt;" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="350" height="30" as="geometry"/>
        </mxCell>

        <!-- ==================== READ SECTION ==================== -->
        <mxCell id="read_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="50" y="60" width="450" height="330" as="geometry"/>
        </mxCell>
        <mxCell id="read_title" value="&lt;b&gt;PM Read (Holographic Modulation)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Inside CorticalColumnGroup.forward — every token, every pass&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="65" width="400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="r_input" value="x_col&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, C, D_col]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="150" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="r_q" value="q = view_5d(x_col)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, B, C, D_col] — free view&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="80" y="165" width="200" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="re1" style="endArrow=block;endFill=1;" edge="1" source="r_input" target="r_q" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PM State -->
        <mxCell id="pm_state" value="&lt;b&gt;PM State&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pm_K [BS, B, r, D_col] (unit-norm)&lt;br&gt;pm_V [BS, B, r, D_col]&lt;br&gt;pm_a [BS, B, r] (strengths)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="300" y="130" width="180" height="65" as="geometry"/>
        </mxCell>

        <!-- Scores -->
        <mxCell id="r_scores" value="scores = norm(q) @ pm_K.T&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, C, r]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="280" y="220" width="190" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="re3" style="endArrow=block;endFill=1;" edge="1" source="r_q" target="r_scores" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="re3b" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="pm_state" target="r_scores" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Weighted + Modulation -->
        <mxCell id="r_weighted" value="weighted = scores × pm_a&lt;br&gt;modulation = weighted @ pm_V&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, B, C, D_col]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="140" y="280" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="re4" style="endArrow=block;endFill=1;" edge="1" source="r_scores" target="r_weighted" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Holographic output -->
        <mxCell id="r_holo" value="y = q ⊙ modulation (holographic)&lt;br&gt;x_col += reshape_g(y)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, G, D_col] — no projection&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="345" width="215" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="re5" style="endArrow=block;endFill=1;" edge="1" source="r_weighted" target="r_holo" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== ELIGIBILITY SECTION ==================== -->
        <mxCell id="elig_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="530" y="60" width="500" height="330" as="geometry"/>
        </mxCell>
        <mxCell id="elig_title" value="&lt;b&gt;PM Eligibility Accumulation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;After full column forward (PM read + EM read + FFN)&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="65" width="400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="e_xout" value="x_out (column output)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, C, D_col]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="650" y="110" width="170" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="e_kcand" value="k_cand = norm(k_pre) from W_post_fused&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, B, C, D_col] — what to store&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="550" y="165" width="220" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="e_vcand" value="v_cand = v_post from W_post_fused&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, B, C, D_col] — modulation pattern&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="790" y="165" width="220" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="ee1" style="endArrow=block;endFill=1;" edge="1" source="e_xout" target="e_kcand" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ee2" style="endArrow=block;endFill=1;" edge="1" source="e_xout" target="e_vcand" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Surprise gate -->
        <mxCell id="e_surprise" value="&lt;font color=&quot;#9673a6&quot;&gt;surprise (from PCM)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="555" y="220" width="130" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="e_gate" value="gate = (surprise / scale).clamp(0, 1)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, C] — only surprising tokens accumulate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="215" width="310" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ee3" style="endArrow=block;endFill=1;" edge="1" source="e_surprise" target="e_gate" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Routing -->
        <mxCell id="e_route" value="route_scores = k_norm @ pm_K.T&lt;br&gt;route_w = softmax(scores / τ_route)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, C, r] — which slots to update&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="272" width="250" height="50" as="geometry"/>
        </mxCell>

        <!-- Aggregation -->
        <mxCell id="e_agg" value="&lt;b&gt;Aggregate across N×C&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;gated_routed = gate × route_w&lt;br&gt;elig_K = Σ_{n,c} gated_routed × k_cand → [BS, B, r, D_col]&lt;br&gt;elig_V = Σ_{n,c} gated_routed × v_cand → [BS, B, r, D_col]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="340" width="380" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ee4" style="endArrow=block;endFill=1;" edge="1" source="e_route" target="e_agg" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ee5" style="endArrow=block;endFill=1;dashed=1;" edge="1" source="e_gate" target="e_agg" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== COMMIT SECTION ==================== -->
        <mxCell id="commit_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="130" y="430" width="800" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="commit_title" value="&lt;b&gt;PM Commit (Between Passes)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;ColumnBlock.commit_and_write — once per pass per block&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="140" y="435" width="400" height="35" as="geometry"/>
        </mxCell>

        <!-- Base decay -->
        <mxCell id="c_decay" value="1. Base Decay&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pm_a *= decay_pm&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="160" y="480" width="150" height="35" as="geometry"/>
        </mxCell>

        <!-- Neuromodulator -->
        <mxCell id="c_neuromod_in" value="Neuromod inputs (detached):&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;elig_summary = ‖elig_K‖.mean() [BS]&lt;br&gt;pm_usage = Σ pm_a [BS]&lt;br&gt;content_emb = mean(elig_K) [BS, D_col]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="160" y="535" width="240" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="c_neuromod" value="&lt;b&gt;PMNeuromodulator&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;MLP: features → backbone(ReLU)&lt;br&gt;→ g_head (sigmoid) → g [BS]&lt;br&gt;→ slot_head → slot_logits [BS, r]&lt;br&gt;→ tau_head (sigmoid scaled) → τ [BS]&lt;br&gt;→ ww_head (sigmoid scaled) → ww [BS]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="450" y="480" width="260" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="ce1" style="endArrow=block;endFill=1;" edge="1" source="c_neuromod_in" target="c_neuromod" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Slot selection -->
        <mxCell id="c_slots" value="2. Slot Selection&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;g *= elig_mag (pass-0 guard)&lt;br&gt;slot_logits −= ww × pm_a (weakness bias)&lt;br&gt;slot_weights = softmax(slot_logits / τ)&lt;br&gt;α = g × slot_weights [BS, r, 1]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="450" y="580" width="260" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ce2" style="endArrow=block;endFill=1;" edge="1" source="c_neuromod" target="c_slots" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- EMA update -->
        <mxCell id="c_ema" value="3. EMA Update&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pm_K = (1 − α) · pm_K + α · norm(elig_K)&lt;br&gt;pm_V = (1 − α) · pm_V + α · norm(elig_V)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="160" y="640" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ce3" style="endArrow=block;endFill=1;" edge="1" source="c_slots" target="c_ema" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Strength + budget -->
        <mxCell id="c_strength" value="4. Strength + Budget&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pm_a = clamp(pm_a + α, 0, a_max)&lt;br&gt;pm_a = budget_enforce(pm_a, budget_pm)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="490" y="650" width="260" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="ce4" style="endArrow=block;endFill=1;" edge="1" source="c_ema" target="c_strength" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Updated state output -->
        <mxCell id="c_output" value="&lt;b&gt;Updated PM State&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Available for next pass's read&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="655" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ce5" style="endArrow=block;endFill=1;" edge="1" source="c_strength" target="c_output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow from elig to commit -->
        <mxCell id="elig_to_commit" style="endArrow=block;endFill=1;strokeColor=#82b366;strokeWidth=2;" edge="1" source="e_agg" target="c_neuromod_in" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Gradient note -->
        <mxCell id="grad_note" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Gradient Flow&lt;/b&gt;&lt;br&gt;loss → next pass's PM read → pm_K&lt;br&gt;→ commit(elig, g, slot_logits, τ, ww)&lt;br&gt;→ neuromod params get gradient&lt;br&gt;&lt;br&gt;Neuromod &lt;i&gt;inputs&lt;/i&gt; are detached.&lt;br&gt;Neuromod &lt;i&gt;outputs&lt;/i&gt; (g, τ, ww) are not.&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="470" width="210" height="120" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
