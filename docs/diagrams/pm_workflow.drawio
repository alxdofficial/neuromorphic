<mxfile host="app.diagrams.net" modified="2026-03-01" type="device">
  <diagram name="Procedural Memory — Bias Vector (v5)" id="pm-workflow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Procedural Memory — Bias Vector with Gain Modulation (v5)&lt;/b&gt;" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- PM State -->
        <mxCell id="pm_state" value="&lt;b&gt;PM State&lt;/b&gt; (one bias vector per bank — state, not params)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;pm_bias [BS, B, D] where D = C × D_col&lt;br&gt;Column c's slice: pm_bias[:, b, c·D_col:(c+1)·D_col]&lt;br&gt;&lt;br&gt;Coarse, automatic, habitual — basal ganglia analog&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="350" y="60" width="350" height="75" as="geometry"/>
        </mxCell>

        <!-- ==================== WRITE DELTAS (Stage 2 — computed first) ==================== -->
        <mxCell id="write_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#d6b656;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="170" width="470" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="write_title" value="&lt;b&gt;PM Write Delta — Per-Token (computed first, parallel)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Each token proposes a bias update from surprise&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="175" width="450" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="u_surprise" value="Vector surprise (from PCM)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, C, D_col] — per-feature prediction error&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="70" y="220" width="220" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="u_delta" value="δ_pm = lr_pm · surprise&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, D] — per-token proposed bias update&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="70" y="270" width="200" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="ue1" style="endArrow=block;endFill=1;" edge="1" source="u_surprise" target="u_delta" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="u_prefix" value="&lt;b&gt;cum_pm = cumsum(δ_pm, dim=seq)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, D] — causal accumulation&lt;br&gt;Position t sees writes from tokens 0..t (inclusive)&lt;br&gt;Inclusive is causal for NTP (logits_t predicts t+1)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="300" y="230" width="210" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ue2" style="endArrow=block;endFill=1;" edge="1" source="u_delta" target="u_prefix" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== READ (Stage 2 — with causal bias) ==================== -->
        <mxCell id="read_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="345" width="470" height="135" as="geometry"/>
        </mxCell>
        <mxCell id="read_title" value="&lt;b&gt;PM Read — Causal Delta Modulation (write-before-read)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Frozen bias + accumulated within-segment updates&lt;br&gt;No matmuls, no routing — just multiply&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="350" width="450" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="r_input" value="H (column states from Stage 1)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, B, D] — per bank&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="70" y="405" width="190" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="r_mod" value="&lt;b&gt;delta_pm = H ⊙ (pm_bias + cum_pm)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, B, D] — delta only (baseline H added once in Stage 3)&lt;br&gt;pm_bias (frozen from prev segment) + cum_pm (causal buffer)&lt;br&gt;Token t's modulation reflects all surprise-driven updates 0..t&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="280" y="400" width="230" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="re1" style="endArrow=block;endFill=1;" edge="1" source="r_input" target="r_mod" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="re1b" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="pm_state" target="r_mod" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="re1c" style="endArrow=block;endFill=1;dashed=1;strokeColor=#d6b656;" edge="1" source="u_prefix" target="r_mod" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== SEGMENT-END COMMIT ==================== -->
        <mxCell id="commit_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#4472C4;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="550" y="170" width="480" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="commit_title" value="&lt;b&gt;PM Segment-End Commit (slow path)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Aggregate all per-token deltas → update pm_bias for next segment&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="175" width="460" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="u_sum" value="pm_bias += Σ_n δ_pm&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Sum all per-token deltas (= cum_pm[N-1])&lt;br&gt;pm_bias now includes segment's adaptation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="580" y="230" width="250" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="u_decay" value="pm_bias *= (1 − decay_pm)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Slow drift back to neutral — prevents runaway&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="580" y="290" width="250" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="ue3" style="endArrow=block;endFill=1;" edge="1" source="u_sum" target="u_decay" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== COMPARISON NOTE ==================== -->
        <mxCell id="note" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Two Write Paths — Fast &amp; Slow&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Fast (within segment):&lt;/b&gt;&lt;br&gt;• cum_pm = prefix sum of δ_pm&lt;br&gt;• Goes into gain formula at each position&lt;br&gt;• Same-segment gradient for lr_pm&lt;br&gt;• Token t benefits from 0..t surprise info&lt;br&gt;&lt;br&gt;&lt;b&gt;Slow (segment end):&lt;/b&gt;&lt;br&gt;• pm_bias += Σ_n δ_pm&lt;br&gt;• Persists to next segment&lt;br&gt;• Cross-segment gradient (TBPTT)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="345" width="240" height="200" as="geometry"/>
        </mxCell>

        <!-- Gradient note -->
        <mxCell id="grad_note" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Gradient Flow&lt;/b&gt;&lt;br&gt;&lt;b&gt;Same-segment:&lt;/b&gt; loss → Stage 3 → delta_pm = H ⊙ (pm_bias + cum_pm)&lt;br&gt;→ cum_pm → δ_pm → lr_pm gets gradient from THIS segment&lt;br&gt;&lt;br&gt;&lt;b&gt;Cross-segment:&lt;/b&gt; loss → next seg reads → pm_bias → commit → lr_pm&lt;br&gt;&lt;br&gt;pm_bias is &lt;b&gt;state&lt;/b&gt; (evolves at inference).&lt;br&gt;lr_pm is a &lt;b&gt;parameter&lt;/b&gt; (trained by backprop via both paths).&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="555" width="340" height="130" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
