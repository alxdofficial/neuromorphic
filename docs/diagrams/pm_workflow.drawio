<mxfile host="app.diagrams.net" modified="2026-03-03" type="device">
  <diagram name="Procedural Memory — Hebbian Fast-Weight Network (v6)" id="pm-workflow">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Procedural Memory — Hebbian Fast-Weight Network (v6)&lt;/b&gt;" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- PM State -->
        <mxCell id="pm_state" value="&lt;b&gt;PM State&lt;/b&gt; (per-bank fast-weight matrix — state, not params)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;W_pm [BS, B, D_pm, D_pm] — D_pm=64 default&lt;br&gt;Initialized as (1/B)·I + noise (approximately identity pass-through)&lt;br&gt;Evolves at inference for lifelong adaptation (~512KB total at BS=16, B=4)&lt;br&gt;&lt;br&gt;Basal ganglia analog — habitual associative transformations&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="310" y="55" width="400" height="85" as="geometry"/>
        </mxCell>

        <!-- ==================== READ (Stage 2) ==================== -->
        <mxCell id="read_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="170" width="470" height="195" as="geometry"/>
        </mxCell>
        <mxCell id="read_title" value="&lt;b&gt;PM Read — Bank-Summed Fast-Weight Transform (Stage 2)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Project to D_pm space, apply learned transform, project back&lt;br&gt;Banks are summed before matmul — no [BS,N,B,D] intermediate&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="175" width="450" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="r_proj_in" value="pre = proj_in(H)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, D] → [BS, N, D_pm] — fixed nn.Linear&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="70" y="230" width="200" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="r_matmul" value="post = (Σ_b W_b) @ pre&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;W_sum = W_pm.sum(dim=1) [BS, D_pm, D_pm]&lt;br&gt;post = pre @ W_sum.T [BS, N, D_pm]&lt;br&gt;Bank-sum fusion: banks invisible at read time&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="70" y="280" width="260" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="re1" style="endArrow=block;endFill=1;" edge="1" source="r_proj_in" target="r_matmul" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="r_proj_out" value="pm_read = proj_out(post)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N, D_pm] → [BS, N, D] — fixed nn.Linear&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="350" y="280" width="155" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="re2" style="endArrow=block;endFill=1;" edge="1" source="r_matmul" target="r_proj_out" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow: pm_state to matmul -->
        <mxCell id="re_state" style="endArrow=block;endFill=1;dashed=1;strokeColor=#82b366;" edge="1" source="pm_state" target="r_matmul" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== WRITE: HEBBIAN COMMIT (segment end) ==================== -->
        <mxCell id="write_container" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#d6b656;dashed=1;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="400" width="950" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="write_title" value="&lt;b&gt;PM Segment-End Commit — Surprise-Gated Hebbian Update&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Efficient right-multiply factorization: W_b = W_b @ (decay·I + β_b·G)&lt;br&gt;Single batched matmul for all banks, then Frobenius budget clip&lt;/font&gt;" style="text;html=1;align=left;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="405" width="500" height="45" as="geometry"/>
        </mxCell>

        <!-- Surprise gate -->
        <mxCell id="w_surprise" value="Surprise gate: s_t = σ(‖surprise_t‖)&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, N] — sigmoid of surprise magnitude&lt;br&gt;High surprise → strong Hebbian update&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="70" y="460" width="230" height="45" as="geometry"/>
        </mxCell>

        <!-- Eligibility matrix -->
        <mxCell id="w_elig" value="G = (1/N) · Σ_t s_t · pre_t ⊗ pre_tᵀ&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;= (1/N) · (√s · pre)ᵀ @ (√s · pre) [BS, D_pm, D_pm]&lt;br&gt;Gated autocorrelation — features that co-activate under&lt;br&gt;surprise have associations reinforced&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="70" y="520" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="we1" style="endArrow=block;endFill=1;" edge="1" source="w_surprise" target="w_elig" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Per-bank transform -->
        <mxCell id="w_transform" value="T_b = decay · I + β_b · G&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;[BS, B, D_pm, D_pm] — per-bank transform matrix&lt;br&gt;β_b = softplus(raw_beta) — learned plasticity rate&lt;br&gt;Fast β = recent habits, slow β = deep associations&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="460" width="260" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="we2" style="endArrow=block;endFill=1;" edge="1" source="w_elig" target="w_transform" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Commit matmul -->
        <mxCell id="w_commit" value="&lt;b&gt;W_b ← W_b @ T_b&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Single batched matmul for all banks [BS, B, D_pm, D_pm]&lt;br&gt;Factorized: no per-token matmul, no per-bank Python loop&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="400" y="530" width="260" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="we3" style="endArrow=block;endFill=1;" edge="1" source="w_transform" target="w_commit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Budget enforcement -->
        <mxCell id="w_budget" value="Frobenius budget clip&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;‖W_b‖_F ≤ budget (default 16.0)&lt;br&gt;Prevents unbounded drift across lifelong use&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="700" y="530" width="200" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="we4" style="endArrow=block;endFill=1;" edge="1" source="w_commit" target="w_budget" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Updated state -->
        <mxCell id="w_output" value="&lt;b&gt;Updated W_pm&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Available for next segment&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="470" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="we5" style="endArrow=block;endFill=1;" edge="1" source="w_budget" target="w_output" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== NOTES ==================== -->
        <mxCell id="note_design" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Why Hebbian Fast Weights&lt;/b&gt;&lt;br&gt;&lt;br&gt;PM is a learned TRANSFORM (input→output).&lt;br&gt;Not a prediction loop (that's PCM).&lt;br&gt;Not content storage (that's EM).&lt;br&gt;&lt;br&gt;• Repeated patterns → W reinforces associations&lt;br&gt;• Surprise gates plasticity → only adapt on errors&lt;br&gt;• Per-bank β → multiple timescales&lt;br&gt;  (fast bank = recent context habits,&lt;br&gt;   slow bank = deep long-term associations)&lt;br&gt;• Bank-sum at read → banks invisible to scan&lt;br&gt;• Frobenius budget → bounded lifelong&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="170" width="250" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="note_gradient" value="&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Gradient Flow&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;Cross-segment (TBPTT):&lt;/b&gt;&lt;br&gt;loss → next seg read → W_pm → commit&lt;br&gt;→ β_b, proj_in, proj_out get gradient&lt;br&gt;&lt;br&gt;&lt;b&gt;No within-segment fast path&lt;/b&gt;&lt;br&gt;(unlike EM's cum_em). PM writes take&lt;br&gt;effect from next segment — matches slower&lt;br&gt;timescale of procedural learning.&lt;br&gt;&lt;br&gt;W_pm is &lt;b&gt;state&lt;/b&gt; (evolves at inference).&lt;br&gt;proj_in/out, β_b are &lt;b&gt;params&lt;/b&gt; (trained).&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;fillColor=none;strokeColor=#999999;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="170" width="200" height="200" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
